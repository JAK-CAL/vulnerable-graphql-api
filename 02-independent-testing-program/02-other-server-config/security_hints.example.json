{
  "auth": {
    "loginOperationName": "Login",
    "loginQuery": "mutation Login($username: String, $password: String) { login(username: $username, password: $password) { id username } }",
    "meOperationName": "AuthSession",
    "meQuery": "query AuthSession { me { id username firstName lastName } }",
    "meResultPath": ["me"]
  },
  "actorLoginVariables": {
    "A": {
      "username": "userA",
      "password": "passwordA"
    },
    "B": {
      "username": "userB",
      "password": "passwordB"
    }
  },
  "operationTags": {
    "securePost": ["secure_hint"],
    "secureComment": ["secure_hint"],
    "internalStats": ["admin_like", "secure_hint"],
    "publicPosts": ["decoy_or_public_hint"],
    "publicComments": ["decoy_or_public_hint"]
  }
}
