  "scripts": {
    "tsc": "tsc",
    "sequelize": "sequelize --config 01-test-target-graphql-server/01-server/config.json --migrations-path 01-test-target-graphql-server/01-server/migrations --seeders-path 01-test-target-graphql-server/01-server/seeders",
    "reset": "sh reset.sh",
    "security:catalog": "node build/02-independent-testing-program/01-test-program/lib/security-testing/cli.js catalog",
    "security:fuzz": "node build/02-independent-testing-program/01-test-program/lib/security-testing/cli.js run",
    "security:fuzz:course": "node build/02-independent-testing-program/01-test-program/lib/security-testing/cli.js run --profile course --out 02-independent-testing-program/03-execution-results/security-results-course",
    "server:02": "PORT=3100 node build/02-test-target-graphql-server/01-server/app.js",
    "security:fuzz:02": "node build/02-independent-testing-program/01-test-program/lib/security-testing/cli.js run --config 02-test-target-graphql-server/02-other-server-config/config.yaml",
    "security:eval": "node build/02-independent-testing-program/01-test-program/lib/security-testing/cli.js eval"
  },
  "dependencies": {
    "@types/bluebird": "3.5.26",
    "@types/cors": "^2.8.5",
    "@types/express": "4.16.1",
    "@types/express-graphql": "^0.8.0",
    "@types/express-rate-limit": "^3.3.3",
    "@types/express-session": "^1.15.12",
    "@types/faker": "^4.1.9",
    "@types/graphql": "^14.2.0",
    "@types/node": "^12.0.1",
    "@types/validator": "^10.11.0",
    "argon2": "^0.44.0",
    "axios": "^0.18.0",
    "cors": "^2.8.5",
    "express": "^4.16.4",
    "express-graphql": "^0.8.0",
    "express-rate-limit": "^5.0.0",
    "express-session": "^1.16.1",
    "faker": "^4.1.0",
    "graphql": "^14.3.0",
    "graphql-type-json": "^0.3.0",
    "sequelize": "^5.21.5",
    "sequelize-cli": "^5.5.1",
    "sqlite3": "^5.1.7",
    "typescript": "^3.4.5"
  }
