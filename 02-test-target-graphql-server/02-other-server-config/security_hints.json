{
  "auth": {
    "loginOperationName": "Login",
    "loginQuery": "mutation Login($username: String, $password: String) { login(username: $username, password: $password) { id username } }",
    "meOperationName": "AuthSession",
    "meQuery": "query AuthSession { me { id username firstName lastName } }",
    "meResultPath": ["me"]
  },
